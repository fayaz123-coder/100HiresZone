# Copy this file to .env and fill in real values. Never commit .env.

# Required for fetch_youtube_videos.py and resolve_channel.py
# Get one free at https://console.cloud.google.com/apis/credentials
# after enabling "YouTube Data API v3" on a project.
YOUTUBE_API_KEY=

# Optional fallback transcript source (https://supadata.ai)
# Only needed if youtube-transcript-api gets rate-limited or a video
# has captions disabled.
SUPADATA_API_KEY=
